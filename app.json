{
  "expo": {
    "name": "fromfeed-app",
    "slug": "fromfeed-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.fromfeed.app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sweizeur.fromfeedapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSSupportsOpeningDocumentsInPlace": false,
        "NSLocationWhenInUseUsageDescription": "FromFeed uses your location to center the map around you.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.fromfeed.app",
              "com.googleusercontent.apps.381924267221-cqoc34bs5ll7fougtki6rq909bffhpjc"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sweizeur.fromfeedapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#04060A"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      ["expo-calendar", { "calendarPermission": "FromFeed ajoute vos sorties à votre calendrier." }],
      ["expo-share-intent", { "disableIOS": true }],
      [
        "expo-share-extension",
        {
          "activationRules": [
            { "type": "url", "max": 1 },
            { "type": "text" }
          ],
          "excludedPackages": [
            "expo-dev-client",
            "expo-splash-screen",
            "expo-updates",
            "expo-font",
            "expo-auth-session",
            "expo-crypto",
            "expo-calendar",
            "expo-clipboard",
            "expo-location",
            "expo-web-browser",
            "expo-image",
            "expo-haptics",
            "expo-linear-gradient",
            "expo-glass-effect",
            "expo-blur",
            "expo-linking",
            "expo-share-intent",
            "expo-symbols",
            "expo-status-bar",
            "expo-system-ui",
            "@expo/vector-icons",
            "@react-native-community/datetimepicker",
            "@react-native-menu/menu",
            "@react-native-picker/picker",
            "@react-native-segmented-control/segmented-control"
          ]
        }
      ],
      "./plugins/with-ats-config.js",
      "./plugins/with-share-extension.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ef7b9df-34c6-4f24-944c-30ca3f3a918c"
      }
    },
    "owner": "sweizeur"
  }
}
