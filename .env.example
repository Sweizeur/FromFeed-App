# Backend API URL
# Backend URL - Utilisez Cloudflare Tunnel pour le développement
# Pour démarrer le tunnel: cd ../fromfeed-backend && ./start-tunnel.sh
# Puis copiez l'URL générée ici
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001
# Exemple avec Cloudflare Tunnel: EXPO_PUBLIC_BACKEND_URL=https://xxxx-xxxx-xxxx.trycloudflare.com

# Mapbox (carte globe) — créer un token sur https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# Google OAuth (client iOS / natif — utilisé pour toute la connexion Google dans l’app)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com

# Utiliser le proxy Expo (true pour développement, false pour production)
EXPO_PUBLIC_USE_PROXY=true

# Sentry (error monitoring) — remplace par ton DSN réel dans .env
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
